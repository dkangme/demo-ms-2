# Google Cloud project ID where Firestore resides
GCP_PROJECT=your-gcp-project-id

# Firestore collection name for clients
FIRESTORE_COLLECTION=clientes

# (Optional) Path to service account JSON key file for local development.
# In Cloud Run this is typically omitted (default credentials are used).
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json

# (Optional) Port for the application (default 8080)
APP_PORT=8080
